#include "stm32f10x.h"                  // Device header

int main(void)
{
	RCC_APB2PeriphClockCmd(RCC_APB2Periph_GPIOC,ENABLE);//启动时钟
	GPIO_InitTypeDef GPIO_InitStructure;// 1. 定义一个GPIO初始化结构体变量
	GPIO_InitStructure.GPIO_Mode = GPIO_Mode_Out_PP;// 2. 设置模式为推挽输出
	GPIO_InitStructure.GPIO_Pin = GPIO_Pin_13;// 3. 指定要配置的引脚是13号引脚
	GPIO_InitStructure.GPIO_Speed = GPIO_Speed_50MHz;// 4. 设置引脚输出速度
	GPIO_Init(GPIOC, &GPIO_InitStructure); // 5. 调用初始化函数，将配置写入硬件寄存器
	GPIO_SetBits(GPIOC,GPIO_Pin_13);;设置高电平
	//GPIO_ResetBits(GPIOC,GPIO_Pin_13);
	while (1)
	{
		
	}

}//最后空一行避免警告
